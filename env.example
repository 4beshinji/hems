# ============================================================
# HEMS (Home Environment Management System) Configuration
# ============================================================
# Copy this file to .env and adjust values as needed:
#   cp env.example .env

# === System ===
LOG_LEVEL=INFO
TZ=Asia/Tokyo
ROOMS=living_room

# === Host Port Mapping ===
# Defaults are offset from SOMS (80/1883/8000-8002) to allow coexistence.
# Override any port to resolve conflicts or match your setup.
# HEMS_PORT_FRONTEND=8080
# HEMS_PORT_BACKEND=8010
# HEMS_PORT_MOCK_LLM=8011
# HEMS_PORT_VOICE=8012
# HEMS_PORT_MQTT=1893
# HEMS_PORT_VOICEVOX=50031
# HEMS_PORT_OLLAMA=11444
# HEMS_PORT_POSTGRES=5442

# === MQTT Broker ===
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_USER=hems
MQTT_PASS=hems_dev_mqtt
# MQTT_BIND_ADDR=127.0.0.1  # Restrict MQTT listener (default: 127.0.0.1)

# === LLM Configuration ===
# Provider: openai | anthropic | ollama
LLM_PROVIDER=openai
# API URL options:
#   http://mock-llm:8000/v1              (Development mock)
#   http://ollama:11434/v1               (Docker Ollama)
#   http://host.docker.internal:11434/v1 (Host Ollama)
#   https://api.openai.com/v1            (OpenAI Cloud)
LLM_API_URL=http://mock-llm:8000/v1
LLM_MODEL=mock
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# === TTS (Text-to-Speech) ===
# Provider: espeak | voicevox | voisona | style-bert-vits2 | edge-tts
TTS_PROVIDER=espeak
# VOICEVOX_URL=http://voicevox:50021
# VOISONA_URL=http://host.docker.internal:32766
# VOISONA_USERNAME=user@example.com
# VOISONA_PASSWORD=api_password
# VOISONA_SHARED_DIR=/tmp/hems-tts
# STYLE_BERT_VITS2_URL=http://host.docker.internal:5000

# === Database ===
# Default: SQLite (no external DB required)
DATABASE_URL=sqlite+aiosqlite:///./data/hems.db
# PostgreSQL (enable with: docker compose --profile postgres up)
# DATABASE_URL=postgresql+asyncpg://hems:hems_dev_password@postgres:5432/hems
# POSTGRES_USER=hems
# POSTGRES_PASSWORD=hems_dev_password

# === AI Character ===
# Built-in templates: ene | tsundere | gentle-senpai | butler
CHARACTER=ene
# Custom character file (overrides CHARACTER):
# CHARACTER_FILE=./config/character.yaml

# === GPU Configuration ===
# Auto-detected by: python infra/scripts/gpu_setup.py
# GPU type: amd | nvidia | none
GPU_TYPE=none
GPU_HIGH_LOAD_THRESHOLD=80
# GPU_NAME=
# GPU_VRAM_MB=

# === Environment Thresholds ===
# Override default thresholds for alerts and rules
# HEMS_THRESHOLD_CO2_HIGH=1000
# HEMS_THRESHOLD_CO2_CRITICAL=1500
# HEMS_THRESHOLD_TEMP_HIGH=28
# HEMS_THRESHOLD_TEMP_LOW=16
# HEMS_THRESHOLD_HUMIDITY_HIGH=70
# HEMS_THRESHOLD_HUMIDITY_LOW=30
# HEMS_THRESHOLD_SEDENTARY_MINUTES=60
# HEMS_THRESHOLD_PC_CPU_HIGH=90
# HEMS_THRESHOLD_PC_MEMORY_HIGH=90
# HEMS_THRESHOLD_PC_GPU_TEMP_HIGH=85
# HEMS_THRESHOLD_PC_DISK_HIGH=90
# HEMS_THRESHOLD_SCREEN_TIME_MINUTES=120

# === OpenClaw Integration (Desktop agent) ===
# Enable with: docker compose --profile openclaw up
# Requires OpenClaw Gateway running on host (ws://localhost:18789)
# OPENCLAW_GATEWAY_URL=ws://host.docker.internal:18789
# OPENCLAW_GATEWAY_TOKEN=
# OPENCLAW_METRICS_INTERVAL=10
# OPENCLAW_PROCESS_INTERVAL=30
# HEMS_PORT_OPENCLAW_BRIDGE=8013
# OPENCLAW_BRIDGE_URL=http://openclaw-bridge:8000

# === Service Monitor (openclaw-bridge) ===
# Gmail (IMAP — requires App Password)
# HEMS_GMAIL_ENABLED=true
# HEMS_GMAIL_EMAIL=user@gmail.com
# HEMS_GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# HEMS_GMAIL_INTERVAL=300
# GitHub (REST API — requires Personal Access Token)
# HEMS_GITHUB_ENABLED=true
# HEMS_GITHUB_TOKEN=ghp_xxxx
# HEMS_GITHUB_INTERVAL=300
# Browser-based checkers (JSON array, requires OpenClaw)
# HEMS_BROWSER_CHECKERS=[]

# === Obsidian Integration (Knowledge store) ===
# Enable with: docker compose --profile obsidian up
# OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
# OBSIDIAN_BRIDGE_URL=http://obsidian-bridge:8000
# OBSIDIAN_WATCHER_DEBOUNCE=2.0
# HEMS_PORT_OBSIDIAN_BRIDGE=8014

# === Persona Rewriter ===
# Rewrite rule-engine speak messages in character voice (adds ~1-3s latency)
# Disable if using local LLM (Ollama) with GPU under high load
# PERSONA_REWRITE_ENABLED=true
# PERSONA_REWRITE_CACHE_TTL=3600

# === GAS Integration (Google Apps Script) ===
# Enable with: docker compose --profile gas up
# Deploy Code.gs as Web App (see scripts/gas-bridge/README.md)
# GAS_WEBAPP_URL=https://script.google.com/macros/s/xxx/exec
# GAS_API_KEY=your-api-key-here
# GAS_BRIDGE_URL=http://gas-bridge:8000
# HEMS_PORT_GAS_BRIDGE=8015
# Polling intervals (seconds)
# HEMS_GAS_CALENDAR_INTERVAL=120
# HEMS_GAS_TASKS_INTERVAL=300
# HEMS_GAS_GMAIL_INTERVAL=300
# HEMS_GAS_SHEETS_INTERVAL=600
# HEMS_GAS_DRIVE_INTERVAL=600
# Sheets to monitor (name:spreadsheet_id:sheet_name:range)
# HEMS_GAS_SHEETS=budget:1xABC:Sheet1:A1:D20

# === Home Assistant Integration (Smart home) ===
# Enable with: docker compose --profile ha up
# Requires Home Assistant running (locally or via Docker)
# HA_URL=http://host.docker.internal:8123
# HA_TOKEN=your-long-lived-access-token
# HA_BRIDGE_URL=http://ha-bridge:8000
# HEMS_PORT_HA_BRIDGE=8016
# HEMS_HA_POLL_INTERVAL=30
# Entity mapping (JSON: {"light.bedroom": {"zone": "bedroom", "domain": "light"}})
# HEMS_HA_ENTITY_MAP={}
# HA config path for containerized HA
# HEMS_HA_CONFIG_PATH=./ha-config

# === Biometric Integration (Smartband) ===
# Enable with: docker compose --profile biometric up
# Requires Gadgetbridge app on phone, configured to send webhooks
# BIOMETRIC_BRIDGE_URL=http://biometric-bridge:8000
# HEMS_PORT_BIOMETRIC_BRIDGE=8017
# BIOMETRIC_PROVIDER=gadgetbridge
# Biometric thresholds
# HEMS_THRESHOLD_HR_HIGH=120
# HEMS_THRESHOLD_HR_LOW=45
# HEMS_THRESHOLD_SPO2_LOW=92
# HEMS_THRESHOLD_STRESS_HIGH=80
# HEMS_THRESHOLD_HRV_LOW=20
# HEMS_THRESHOLD_BODY_TEMP_HIGH=37.5
# HEMS_THRESHOLD_RESPIRATORY_RATE_HIGH=25

# === External Integrations (Phase 2: data-bridge) ===
# Google Calendar
# GOOGLE_CALENDAR_CREDENTIALS=./config/google_credentials.json
# Strava
# STRAVA_CLIENT_ID=...
# STRAVA_CLIENT_SECRET=...
# Fitbit
# FITBIT_CLIENT_ID=...
# FITBIT_CLIENT_SECRET=...
# Garmin
# GARMIN_USERNAME=...
# GARMIN_PASSWORD=...
# Intervals.icu
# INTERVALS_ICU_API_KEY=...
# INTERVALS_ICU_ATHLETE_ID=i12345
# Mi Band
# MIBAND_MODE=ble  # ble | gadgetbridge | none
# MIBAND_BLE_ADDRESS=XX:XX:XX:XX:XX:XX

# === AMD GPU (ROCm) ===
# HSA_OVERRIDE_GFX_VERSION=12.0.1

# === NVIDIA GPU ===
# Requires nvidia-container-toolkit:
#   sudo apt-get install -y nvidia-container-toolkit
#   sudo nvidia-ctk runtime configure --runtime=docker
#   sudo systemctl restart docker

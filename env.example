# ============================================================
# HEMS (Home Environment Management System) Configuration
# ============================================================
# Copy this file to .env and adjust values as needed:
#   cp env.example .env

# === System ===
LOG_LEVEL=INFO
TZ=Asia/Tokyo
ROOMS=living_room

# === Host Port Mapping ===
# Defaults are offset from SOMS (80/1883/8000-8002) to allow coexistence.
# Override any port to resolve conflicts or match your setup.
# HEMS_PORT_FRONTEND=8080
# HEMS_PORT_BACKEND=8010
# HEMS_PORT_MOCK_LLM=8011
# HEMS_PORT_VOICE=8012
# HEMS_PORT_MQTT=1893
# HEMS_PORT_VOICEVOX=50031
# HEMS_PORT_OLLAMA=11444
# HEMS_PORT_POSTGRES=5442

# === MQTT Broker ===
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_USER=hems
MQTT_PASS=hems_dev_mqtt
# MQTT_BIND_ADDR=127.0.0.1  # Restrict MQTT listener (default: 127.0.0.1)

# === LLM Configuration ===
# Provider: openai | anthropic | ollama
LLM_PROVIDER=openai
# API URL options:
#   http://mock-llm:8000/v1              (Development mock)
#   http://ollama:11434/v1               (Docker Ollama)
#   http://host.docker.internal:11434/v1 (Host Ollama)
#   https://api.openai.com/v1            (OpenAI Cloud)
LLM_API_URL=http://mock-llm:8000/v1
LLM_MODEL=mock
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# === TTS (Text-to-Speech) ===
# Provider: espeak | voicevox | voisona | style-bert-vits2 | edge-tts
TTS_PROVIDER=espeak
# VOICEVOX_URL=http://voicevox:50021
# VOISONA_URL=http://host.docker.internal:32766
# VOISONA_USERNAME=user@example.com
# VOISONA_PASSWORD=api_password
# VOISONA_SHARED_DIR=/tmp/hems-tts
# STYLE_BERT_VITS2_URL=http://host.docker.internal:5000

# === Database ===
# Default: SQLite (no external DB required)
DATABASE_URL=sqlite+aiosqlite:///./data/hems.db
# PostgreSQL (enable with: docker compose --profile postgres up)
# DATABASE_URL=postgresql+asyncpg://hems:hems_dev_password@postgres:5432/hems
# POSTGRES_USER=hems
# POSTGRES_PASSWORD=hems_dev_password

# === AI Character ===
# Built-in templates: tsundere | gentle-senpai | butler
# CHARACTER=tsundere
# Custom character file (overrides CHARACTER):
# CHARACTER_FILE=./config/character.yaml

# === GPU Load Monitoring ===
# GPU type: amd | nvidia | none
GPU_TYPE=none
GPU_HIGH_LOAD_THRESHOLD=80

# === OpenClaw Integration (Desktop agent) ===
# Enable with: docker compose --profile openclaw up
# Requires OpenClaw Gateway running on host (ws://localhost:18789)
# OPENCLAW_GATEWAY_URL=ws://host.docker.internal:18789
# OPENCLAW_GATEWAY_TOKEN=
# OPENCLAW_METRICS_INTERVAL=10
# OPENCLAW_PROCESS_INTERVAL=30
# HEMS_PORT_OPENCLAW_BRIDGE=8013
# OPENCLAW_BRIDGE_URL=http://openclaw-bridge:8000

# === Service Monitor (openclaw-bridge) ===
# Gmail (IMAP — requires App Password)
# HEMS_GMAIL_ENABLED=true
# HEMS_GMAIL_EMAIL=user@gmail.com
# HEMS_GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# HEMS_GMAIL_INTERVAL=300
# GitHub (REST API — requires Personal Access Token)
# HEMS_GITHUB_ENABLED=true
# HEMS_GITHUB_TOKEN=ghp_xxxx
# HEMS_GITHUB_INTERVAL=300
# Browser-based checkers (JSON array, requires OpenClaw)
# HEMS_BROWSER_CHECKERS=[]

# === External Integrations (Phase 2: data-bridge) ===
# Google Calendar
# GOOGLE_CALENDAR_CREDENTIALS=./config/google_credentials.json
# Strava
# STRAVA_CLIENT_ID=...
# STRAVA_CLIENT_SECRET=...
# Fitbit
# FITBIT_CLIENT_ID=...
# FITBIT_CLIENT_SECRET=...
# Garmin
# GARMIN_USERNAME=...
# GARMIN_PASSWORD=...
# Intervals.icu
# INTERVALS_ICU_API_KEY=...
# INTERVALS_ICU_ATHLETE_ID=i12345
# Mi Band
# MIBAND_MODE=ble  # ble | gadgetbridge | none
# MIBAND_BLE_ADDRESS=XX:XX:XX:XX:XX:XX

# === AMD GPU (ROCm) ===
# HSA_OVERRIDE_GFX_VERSION=12.0.1

# ============================================================
# HEMS Lite — environment variables
# Copy to .env: cp env.lite.example .env
# ============================================================

# --- Site Identity ---
SITE_ID=grandma-house
SITE_NAME=おばあちゃんの家

# --- Operation Mode ---
# standalone: local notifications only
# satellite:  forward data to main HEMS via MQTT bridge
# hybrid:     standalone + escalate CRITICAL to main HEMS
HEMS_LITE_MODE=standalone

# --- Timezone ---
TZ=Asia/Tokyo

# --- Notification (configure at least one) ---
# LINE Notify (https://notify-bot.line.me/)
# LINE_NOTIFY_TOKEN=your-token

# Discord Webhook
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx

# Slack Incoming Webhook
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# ntfy (self-hostable: https://ntfy.sh)
# NTFY_TOPIC=hems-lite-grandma
# NTFY_SERVER=https://ntfy.sh

# Minimum level for instant notifications (CRITICAL|HIGH|NORMAL|INFO)
NOTIFY_MIN_LEVEL=HIGH

# Daily summary
DAILY_SUMMARY_ENABLED=true
DAILY_SUMMARY_TIME=08:00

# --- LLM Escalation (gray zone analysis) ---
# Needed for gray zone detection. Without this, only rule-based alerts work.
# Option 1: OpenAI
# LLM_PROVIDER=openai
# LLM_API_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=gpt-4o-mini

# Option 2: Anthropic
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-xxx
# LLM_MODEL=claude-haiku-4-5-20251001

# Budget: max LLM calls per day (cost control, ~$0.01-0.05 per call)
LLM_DAILY_BUDGET=50
# Cooldown between same-pattern escalations (seconds)
LLM_ESCALATION_COOLDOWN=600

# --- Biometric Thresholds ---
# Critical (immediate alert, no cooldown)
HR_CRITICAL_HIGH=150
HR_CRITICAL_LOW=40
SPO2_CRITICAL=88

# High priority (5min cooldown)
HR_HIGH=120
HR_LOW=45
SPO2_LOW=92
STRESS_HIGH=80
BODY_TEMP_HIGH=37.5

# Environment (for elderly: wider comfort range)
TEMP_HIGH=32
TEMP_LOW=10
TEMP_WARN_HIGH=28
TEMP_WARN_LOW=16

# Activity monitoring
SEDENTARY_ALERT_MINUTES=90
ABSENCE_ALERT_MINUTES=120
LYING_DAYTIME_MINUTES=180

# --- Sentinel ---
SENTINEL_CYCLE_INTERVAL=60
LOG_LEVEL=INFO

# --- Biometric Bridge (profile: biometric) ---
# BIOMETRIC_WEBHOOK_SECRET=your-secret
# BIOMETRIC_PROVIDER=gadgetbridge

# --- Perception (profile: perception) ---
# HEMS_PERCEPTION_CAMERAS=[{"device_id":"cam01","zone":"living_room","type":"stream","url":"rtsp://..."}]
# HEMS_PERCEPTION_INTERVAL=30

# --- Home Assistant (profile: ha) ---
# HA_URL=http://host.docker.internal:8123
# HA_TOKEN=your-long-lived-access-token

# --- MQTT (usually no change needed) ---
# HEMS_PORT_MQTT=1893
# MQTT_USER=
# MQTT_PASS=

# --- Satellite mode (when HEMS_LITE_MODE=satellite or hybrid) ---
# Configure in infra/mosquitto/bridge.conf
# HEMS_MAIN_MQTT_HOST=main-hems.example.com
# HEMS_MAIN_MQTT_PORT=1893
